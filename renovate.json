{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "before 10am on monday"
  ],
  "timezone": "Asia/Qatar",
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "description": "Group Astro packages together",
      "groupName": "Astro",
      "matchPackagePatterns": [
        "^@astrojs/",
        "^astro$"
      ]
    },
    {
      "description": "Group Lucide icons together",
      "groupName": "Lucide Icons",
      "matchPackagePatterns": [
        "^@lucide/",
        "^lucide-"
      ]
    },
    {
      "description": "Group React packages together",
      "groupName": "React",
      "matchPackagePatterns": [
        "^react",
        "^@types/react"
      ]
    },
    {
      "description": "Group Tailwind packages together",
      "groupName": "Tailwind CSS",
      "matchPackagePatterns": [
        "^tailwindcss",
        "^@tailwindcss/",
        "tailwind-merge"
      ]
    },
    {
      "description": "Automerge patch and minor updates for dev dependencies",
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true
    },
    {
      "description": "Automerge security patches",
      "matchUpdateTypes": [
        "patch"
      ],
      "matchPackagePatterns": [
        "*"
      ],
      "automerge": true,
      "automergeType": "pr",
      "labels": [
        "security",
        "automerge"
      ]
    },
    {
      "description": "Require manual approval for major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "labels": [
        "major-update"
      ]
    }
  ],
  "vulnerabilityAlerts": {
    "labels": [
      "security",
      "critical"
    ],
    "automerge": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 10am on the first day of the month"
    ]
  },
  "rangeStrategy": "bump",
  "semanticCommits": "enabled",
  "commitMessagePrefix": "chore(deps):",
  "commitMessageAction": "update",
  "commitMessageTopic": "{{depName}}",
  "prCreation": "immediate",
  "platformAutomerge": true
}
