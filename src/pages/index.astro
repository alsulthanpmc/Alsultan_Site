---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Hero from '@/components/Hero.astro';
import QuickStats from '@/components/QuickStats';
import About from '@/components/About.astro';
import WhyChooseUs from '@/components/WhyChooseUs.astro';
// Departments merged into Services - removed separate component import
import Services from '@/components/Services';
import DoctorsSlider from '@/components/DoctorsSlider';
import ContactForm from '@/components/ContactForm';

import { getCollection } from 'astro:content';
import doctorsData from '@/data/doctors.json';
import contactData from '@/data/contact.json';

// Fetch content collections
const departments = await getCollection('departments');
const services = await getCollection('services');

// Simple data passing - components will handle rendering
const departmentsData = departments.map(dept => ({
  id: dept.id,
  slug: dept.slug,
  data: dept.data,
}));

const servicesData = services.map(service => ({
  id: service.id,
  slug: service.slug,
  data: service.data,
}));
---

<BaseLayout>
  <Header />
  
  <main>
    <!-- Hero Section -->
    <Hero />
    
    <!-- Quick Stats -->
    <QuickStats client:visible />
    
    <!-- About Section -->
    <About />
    
    <!-- Why Choose Us -->
    <WhyChooseUs />
    
    <!-- Services Section (includes Departments) -->
    <Services client:visible services={servicesData} departments={departmentsData} />
    
    <!-- Doctors Section -->
    <DoctorsSlider client:visible doctors={doctorsData} />
    
    <!-- Contact Section -->
    <ContactForm client:visible contactInfo={contactData} />
  </main>
  
  <Footer />
</BaseLayout>
