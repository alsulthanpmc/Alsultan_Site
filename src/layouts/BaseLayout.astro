---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Al Sultan Premier Medical Center | Healthcare in Doha, Qatar',
  description = 'Premier healthcare in Doha, Qatar. Expert doctors in dental care, dermatology, physiotherapy & more. Book your appointment today.',
  // Legacy bilingual description preserved for reference:
  // 'مركز السلطان الطبي في الدوحة - قطر. خدمات طبية متكاملة، أطباء خبراء. Al Sultan PMC - Premier healthcare in Qatar with expert doctors. Book your appointment today in Doha, Qatar.',
} = Astro.props;

const siteUrl = Astro.site || 'https://sultanpremier.com';
const ogImageUrl = new URL('/cover.jpg', siteUrl).toString();

import '@/styles/global.css';
import WhatsAppButton from '@/components/WhatsAppButton.astro';
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="مركز طبي قطر, Al Sultan Medical Center Qatar, Doha medical center, مركز السلطان الطبي, Qatar healthcare, Doha doctors, dental clinic Qatar, dermatology Qatar, physiotherapy Qatar, عيادة الدوحة, طبيب قطر, Al Khartiyath clinic, مركز طبي الخرطيات" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Al Sultan Premier Medical Center" />
    <meta name="robots" content="index, follow" />
    <meta name="facebook-domain-verification" content="cdlhmzg1x0cqd7axkmwu3utbya2tri" />
    <link rel="canonical" href={siteUrl} />
    
    <!-- Geo Tags for Qatar -->
    <meta name="geo.region" content="QA" />
    <meta name="geo.placename" content="Doha" />
    <meta name="geo.position" content="25.354826;51.183884" />
    <meta name="ICBM" content="25.354826, 51.183884" />
    
    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="Al Sultan Premier Medical Center" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Al Sultan Premier Medical Center - Qatar" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="ar_QA" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="Al Sultan Premier Medical Center - Qatar" />
    
    <!-- WhatsApp Specific -->
    <meta property="og:image:secure_url" content={ogImageUrl} />
    
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <title>{title}</title>
    
    <!-- Schema.org markup for medical clinic in Qatar -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MedicalClinic",
      "name": "Al Sultan Premier Medical Center",
      "alternateName": "مركز السلطان الطبي",
      "image": ogImageUrl,
      "logo": new URL('/logo.png', siteUrl).toString(),
      "description": description,
      "url": siteUrl,
      "telephone": "+974 3000 5925",
      "email": "info@alsultanpmc.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Building No: 7, Street 445, Al Khartiyath",
        "addressLocality": "Doha",
        "addressRegion": "Doha",
        "postalCode": "",
        "addressCountry": "QA"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "25.354826",
        "longitude": "51.183884"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Saturday", "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday"],
          "opens": "08:00",
          "closes": "22:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Friday",
          "opens": "16:00",
          "closes": "22:00"
        }
      ],
      "medicalSpecialty": [
        "GeneralPractice",
        "Dentistry",
        "Dermatology",
        "Physiotherapy",
        "LaboratoryService"
      ],
      "areaServed": {
        "@type": "City",
        "name": "Doha",
        "containedIn": {
          "@type": "Country",
          "name": "Qatar"
        }
      },
      "priceRange": "$$",
      "sameAs": [
        "https://www.facebook.com/alsultanpmc",
        "https://www.instagram.com/alsultanpmc/",
        "https://www.tiktok.com/@alsultanpmc",
        "https://snapchat.com/t/sRCPBGzs"
      ]
    })} />
  </head>
  <body>
    <WhatsAppButton />
    <slot />
    
    <!-- Global Animation Initialization Script -->
    <script is:inline>
    (function() {
      function initAnimations() {
        var els = document.querySelectorAll('.animate-on-scroll');
        if (!els.length) return;

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        els.forEach(function(el) {
          if (!el.classList.contains('visible')) {
            var rect = el.getBoundingClientRect();
            if (rect.top < window.innerHeight && rect.bottom > 0 && rect.width > 0 && rect.height > 0) {
              el.classList.add('visible');
            } else {
              observer.observe(el);
            }
          }
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAnimations);
      } else {
        requestAnimationFrame(initAnimations);
      }
    })();
    </script>
  </body>
</html>
