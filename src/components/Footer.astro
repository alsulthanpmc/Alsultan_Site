---

<footer class="bg-brand-green text-white border-t border-brand-green/80">
  <div class="container mx-auto container-padding section-padding">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Clinic Info -->
      <div class="md:col-span-2">
        <div class="mb-4">
          <img 
              src="/logo.png" 
            alt="Al Sultan Premier Medical Center" 
            class="h-12 w-auto mb-4"
          />
        </div>
        <p class="text-white/90 mb-4 max-w-md">
          Excellence in Healthcare, Compassion in Care. Serving the community since 2020 with world-class medical services.
        </p>
        <div class="flex flex-wrap gap-3">
          {visibleSocials.map(({ key, label }) => (
            <a
              href={contactData.social[key]}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 bg-white/10 hover:bg-brand-blue rounded-lg flex items-center justify-center transition-all hover:scale-110 hover:shadow-lg hover:shadow-brand-blue/30"
              aria-label={label}
              set:html={iconMap[key]}
            />
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-semibold text-lg mb-4">Quick Links</h3>
        <ul class="space-y-2">
          <li><a href="#home" class="text-white/80 hover:text-white transition-colors">Home</a></li>
          <li><a href="#about" class="text-white/80 hover:text-white transition-colors">About Us</a></li>
          <li><a href="#departments" class="text-white/80 hover:text-white transition-colors">Departments</a></li>
          <li><a href="#services" class="text-white/80 hover:text-white transition-colors">Services</a></li>
          <li><a href="#doctors" class="text-white/80 hover:text-white transition-colors">Our Doctors</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="font-semibold text-lg mb-4">Contact</h3>
        <ul class="space-y-3 text-white/90">
          <li class="flex items-start">
            <Phone class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" />
            <span>{contactData.phone}</span>
          </li>
          <li class="flex items-start">
            <Mail class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" />
            <span>{contactData.email}</span>
          </li>
          <li class="flex items-start">
            <MapPin class="w-5 h-5 mr-2 flex-shrink-0 mt-0.5" />
            <span>{contactData.address}</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/20 mt-12 pt-8 text-center text-white/80">
      <p>&copy; {new Date().getFullYear()} Al Sultan Premier Medical Center. All rights reserved.</p>
    </div>
  </div>
</footer>
